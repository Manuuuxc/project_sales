{
  "name": "Financeiro Premium Dark",
  "dataColors": [
    "#38BDF8",
    "#22C55E",
    "#EF4444",
    "#F59E0B",
    "#A78BFA",
    "#14B8A6",
    "#CBD5E1",
    "#64748B",
    "#60A5FA",
    "#34D399",
    "#F87171",
    "#FBBF24"
  ],
  "foreground": "#E5E7EB",
  "foregroundNeutralSecondary": "#94A3B8",
  "foregroundNeutralTertiary": "#64748B",
  "background": "#0B1020",
  "backgroundLight": "#111827",
  "backgroundNeutral": "#1F2937",
  "tableAccent": "#38BDF8",
  "good": "#22C55E",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "maximum": "#38BDF8",
  "center": "#F59E0B",
  "minimum": "#EF4444",
  "null": "#64748B",
  "hyperlink": "#38BDF8",
  "visitedHyperlink": "#38BDF8",
  "textClasses": {
    "callout": {
      "fontSize": 34,
      "fontFace": "Segoe UI Semibold",
      "color": "#F8FAFC"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#F8FAFC"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#E5E7EB"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#CBD5E1"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#111827"
              }
            },
            "transparency": 4
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#263348"
              }
            },
            "radius": 8
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "titleWrap": true
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#CBD5E1"
              }
            }
          }
        ],
        "legend": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#CBD5E1"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "showAxisTitle": false,
            "gridlineStyle": "dotted",
            "concatenateLabels": false,
            "labelColor": {
              "solid": {
                "color": "#CBD5E1"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "showAxisTitle": false,
            "gridlineStyle": "dotted",
            "labelColor": {
              "solid": {
                "color": "#CBD5E1"
              }
            }
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 3
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#0B1020"
              }
            },
            "transparency": 0,
            "border": true,
            "borderColor": {
              "solid": {
                "color": "#263348"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "transparency": 0,
            "foregroundColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "border": true
          },
          {
            "$id": "Available",
            "transparency": 0,
            "foregroundColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "border": true
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#0B1020"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#020617"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#94A3B8"
              }
            }
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#F8FAFC"
              }
            }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#0F172A"
              }
            },
            "transparency": 0
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "padding": 4
          }
        ],
        "header": [
          {
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            }
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "outlineColor": {
              "solid": {
                "color": "#263348"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "backColor": {
              "solid": {
                "color": "#1E293B"
              }
            }
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "backColor": {
              "solid": {
                "color": "#111827"
              }
            }
          }
        ]
      }
    }
  }
}