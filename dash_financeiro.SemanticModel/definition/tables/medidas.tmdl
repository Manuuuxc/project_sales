		displayFolder: 02 Temporal
		lineageTag: 61fbbd87-5c41-485d-b643-d4be6e76c661

	measure 'Variacao Resultado vs Mes Anterior' = [Resultado] - [Resultado Mes Anterior]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: 8ac717d3-0b0f-44db-b165-59a47759c4ab

	measure 'Variacao Resultado % vs Mes Anterior' = DIVIDE ( [Variacao Resultado vs Mes Anterior], [Resultado Mes Anterior] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 02 Temporal
		lineageTag: e99f2e4f-343b-484d-8702-7e7441a6f03b

	measure 'Receita Acumulada' = ```
			
			VAR DataAtual = MAX ( dim_calendario[Data] )
			RETURN
			    CALCULATE (
			        [Receita Total],
			        FILTER (
			            ALLSELECTED ( dim_calendario[Data] ),
			            dim_calendario[Data] <= DataAtual
			        )
			    )
			
			```
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: 4b43b02b-1748-4f87-b1de-a5a9b15c6ac3

	measure 'Despesa Acumulada' = ```
			
			VAR DataAtual = MAX ( dim_calendario[Data] )
			RETURN
			    CALCULATE (
			        [Despesa Total],
			        FILTER (
			            ALLSELECTED ( dim_calendario[Data] ),
			            dim_calendario[Data] <= DataAtual
			        )
			    )
			
			```
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: f862d106-87f7-4352-8e75-010d9fa1829f

	measure 'Resultado Acumulado' = [Receita Acumulada] - [Despesa Acumulada]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: c89d0f97-2600-4f1d-b12c-cb18d93a7d97

