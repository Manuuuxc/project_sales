	measure 'Periodo Selecionado Texto' =
			VAR DataMin = MIN ( dim_calendario[Data] )
			VAR DataMax = MAX ( dim_calendario[Data] )
			RETURN
			    IF (
			        ISBLANK ( DataMin ) || ISBLANK ( DataMax ),
			        "Periodo nao filtrado",
			        FORMAT ( DataMin, "dd/mm/yyyy" ) & " - " & FORMAT ( DataMax, "dd/mm/yyyy" )
			    )
		isHidden
		displayFolder: 05 HTML
		lineageTag: 0b425f16-cedc-4ff6-8a60-f2a0f50c1f18

	measure 'HTML Header Visao' =
			"<div style='box-sizing:border-box;height:100%;padding:18px 22px;border-radius:18px;background:linear-gradient(135deg,#101B2E 0%,#0B1324 62%,#08111F 100%);border:1px solid rgba(148,163,184,.16);box-shadow:0 18px 38px rgba(0,0,0,.28);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC;overflow:hidden;position:relative'>"
			& "<div style='position:absolute;right:-70px;top:-95px;width:220px;height:220px;border-radius:999px;background:radial-gradient(circle,rgba(56,189,248,.22),rgba(56,189,248,0) 66%)'></div>"
			& "<div style='font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#38BDF8;font-weight:700'>Finance Executive Suite</div>"
			& "<div style='margin-top:7px;font-size:26px;line-height:31px;font-weight:700'>Visao Executiva</div>"
			& "<div style='margin-top:4px;font-size:12px;color:#94A3B8'>Saude financeira consolidada | " & [Periodo Selecionado Texto] & "</div>"
			& "</div>"
		displayFolder: 05 HTML
