	measure 'HTML Insights Visao' =
			
			VAR _Status =
			    IF ( [Resultado] >= 0, "financeiramente saudável", "em ponto de atenção" )
			VAR _Cor =
			    IF ( [Resultado] >= 0, "#34D399", "#F87171" )
			VAR _Badge =
			    IF (
			        [Resultado] >= 0,
			        "Resultado positivo no período selecionado",
			        "Resultado negativo no período selecionado"
			    )
			RETURN
			    "<div style='box-sizing:border-box;height:100%;padding:22px;border-radius:20px;background:linear-gradient(135deg,#0F1B2D 0%,#111F33 100%);border:1px solid rgba(255,255,255,.08);box-shadow:0 18px 45px rgba(0,0,0,.28);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
			    & "<div style='font-size:12px;letter-spacing:1.6px;text-transform:uppercase;color:#F59E0B;font-weight:800'>Resumo executivo</div>"
			    & "<div style='margin-top:12px;font-size:24px;line-height:30px;font-weight:750'>O período está <span style='color:" & _Cor & "'>" & _Status & "</span>.</div>"
			    & "<div style='margin-top:12px;display:inline-flex;padding:7px 11px;border-radius:999px;background:rgba(56,189,248,.12);color:#BAE6FD;font-size:12px;font-weight:700'>" & _Badge & "</div>"
			    & "<div style='margin-top:22px;display:grid;grid-template-columns:1fr 1fr;gap:12px'>"
			    & "<div style='padding:14px;border-radius:14px;background:rgba(34,197,94,.09);border:1px solid rgba(34,197,94,.12)'><div style='font-size:11px;color:#94A3B8'>Receita</div><div style='margin-top:6px;font-size:16px;font-weight:750'>" & FORMAT ( [Receita Total], "R$ #,##0.00" ) & "</div></div>"
			    & "<div style='padding:14px;border-radius:14px;background:rgba(239,68,68,.09);border:1px solid rgba(239,68,68,.12)'><div style='font-size:11px;color:#94A3B8'>Despesa</div><div style='margin-top:6px;font-size:16px;font-weight:750'>" & FORMAT ( [Despesa Total], "R$ #,##0.00" ) & "</div></div>"
			    & "<div style='padding:14px;border-radius:14px;background:rgba(56,189,248,.09);border:1px solid rgba(56,189,248,.12)'><div style='font-size:11px;color:#94A3B8'>Resultado</div><div style='margin-top:6px;font-size:16px;font-weight:750;color:" & _Cor & "'>" & FORMAT ( [Resultado], "R$ #,##0.00" ) & "</div></div>"
			    & "<div style='padding:14px;border-radius:14px;background:rgba(245,158,11,.09);border:1px solid rgba(245,158,11,.12)'><div style='font-size:11px;color:#94A3B8'>Margem</div><div style='margin-top:6px;font-size:16px;font-weight:750'>" & FORMAT ( [Margem de Resultado %], "0.0%" ) & "</div></div>"
			    & "</div></div>"
		displayFolder: 05 HTML
		lineageTag: 35c212b1-5eda-4fb1-bc7f-4f81738863d2

