	measure 'Cor Resultado' = IF ( [Resultado] >= 0, "#22C55E", "#EF4444" )
		displayFolder: 04 Indicadores
		lineageTag: 5e16958b-2d9a-4c82-8fa9-59fb8c1024ba

	measure 'Cor Variacao Receita' = IF ( [Variacao Receita vs Mes Anterior] >= 0, "#22C55E", "#EF4444" )
