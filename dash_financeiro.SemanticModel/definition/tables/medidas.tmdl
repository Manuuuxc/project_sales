	measure 'HTML Filter Panel' =
			"<div style='box-sizing:border-box;height:100%;padding:16px;border-radius:18px;background:linear-gradient(180deg,rgba(15,23,42,.96),rgba(8,15,28,.96));border:1px solid rgba(148,163,184,.14);box-shadow:0 18px 38px rgba(0,0,0,.24);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
