table medidas
	lineageTag: f7632a55-01ca-4e5f-88f6-3e1d77124588

	measure 'Receita Total' = ```
			
			VAR Receita =
			    CALCULATE (
			        SUM ( fat_lancamentos_financeiros[valor] ),
			        KEEPFILTERS ( fat_lancamentos_financeiros[tipo] = "RECEITA" )
			    )
			RETURN
			    COALESCE ( Receita, 0 )
			
			```
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 01 Base
		lineageTag: db8ebaf4-b1de-448c-9d10-a49dc074e7f1

	measure 'Despesa Total' = ```
			
			VAR Despesa =
			    CALCULATE (
			        SUM ( fat_lancamentos_financeiros[valor] ),
			        KEEPFILTERS ( fat_lancamentos_financeiros[tipo] = "DESPESA" )
			    )
			RETURN
			    COALESCE ( Despesa, 0 )
			
			```
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 01 Base
		lineageTag: 7ecb3610-a39a-4093-931d-ab49894006e5

	measure Resultado = [Receita Total] - [Despesa Total]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 01 Base
		lineageTag: c0cfd5d2-3d7e-4c89-b986-ba1e5fbfec46

	measure 'Margem de Resultado %' = DIVIDE ( [Resultado], [Receita Total] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01 Base
		lineageTag: 77b6dc56-73f6-4669-bde4-44a7950dff2e

	measure '% Receita por Categoria' = ```
			
			DIVIDE (
			    [Receita Total],
			    CALCULATE ( [Receita Total], REMOVEFILTERS ( dim_categoria ) )
			)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 03 Participacao
		lineageTag: 340abe5d-b83d-4cc0-82de-dd968547142d

	measure 'Receita Mes Anterior' = ```
			
			CALCULATE (
			    [Receita Total],
			    DATEADD ( dim_calendario[Data], -1, MONTH )
			)
			
			```
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: 070db358-1830-4318-92e0-4d849a9d986a

	measure 'Despesa Mes Anterior' = ```
			
			CALCULATE (
			    [Despesa Total],
			    DATEADD ( dim_calendario[Data], -1, MONTH )
			)
			
			```
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: f1f2539f-24f8-45bb-83bb-dbd0dafd90fc

	measure 'Resultado Mes Anterior' = [Receita Mes Anterior] - [Despesa Mes Anterior]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: 6f6bee33-2796-4395-a41e-b4629f4f9707

	measure Saldo = [Resultado]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 01 Base
		lineageTag: 08c11ac7-611d-4e1a-9b53-f0d7bda41c11

	measure 'Total de Lancamentos' = COUNTROWS ( fat_lancamentos_financeiros )
		formatString: #,##0
		displayFolder: 01 Base
		lineageTag: d9f2e3c0-5f9f-46bc-8c80-3f3f9ad9d001

	measure 'Lancamentos de Receita' = ```
			
			CALCULATE (
			    [Total de Lancamentos],
			    KEEPFILTERS ( fat_lancamentos_financeiros[tipo] = "RECEITA" )
			)
			
			```
		formatString: #,##0
		isHidden
		displayFolder: 00 Auxiliares
		lineageTag: 7f92c12e-9ca2-4d1e-bf86-093d7d2d9e02

	measure 'Lancamentos de Despesa' = ```
			
			CALCULATE (
			    [Total de Lancamentos],
			    KEEPFILTERS ( fat_lancamentos_financeiros[tipo] = "DESPESA" )
			)
			
			```
		formatString: #,##0
