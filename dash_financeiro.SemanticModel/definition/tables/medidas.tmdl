	measure 'HTML Header Detalhamento' =
			"<div style='box-sizing:border-box;height:100%;padding:18px 22px;border-radius:18px;background:linear-gradient(135deg,#101B2E 0%,#101827 62%,#07111F 100%);border:1px solid rgba(148,163,184,.16);box-shadow:0 18px 38px rgba(0,0,0,.28);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC;overflow:hidden;position:relative'>"
