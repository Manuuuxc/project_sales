	measure 'Texto Variacao Receita' = ```
			
			VAR Variacao = [Variacao Receita % vs Mes Anterior]
			RETURN
			    IF (
			        ISBLANK ( Variacao ),
			        "Sem base comparativa",
			        FORMAT ( Variacao, "+0.0%;-0.0%;0.0%" ) & " vs mes anterior"
			    )
			
			```
		displayFolder: 04 Indicadores
		lineageTag: 95543dbd-8dcb-4512-807f-1ffec32dc3a3

