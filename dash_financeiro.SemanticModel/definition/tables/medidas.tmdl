			& "<div style='margin-top:7px;font-size:26px;line-height:31px;font-weight:700'>Detalhamento</div>"
			& "<div style='margin-top:4px;font-size:12px;color:#94A3B8'>Consulta granular dos lancamentos | " & [Periodo Selecionado Texto] & "</div>"
