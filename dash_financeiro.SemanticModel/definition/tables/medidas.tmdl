			& "<div style='margin-top:18px;padding:10px 12px;border-radius:12px;background:rgba(56,189,248,.10);border:1px solid rgba(56,189,248,.14);font-size:11px;color:#BAE6FD'>Para limpar filtros, use o icone de borracha do proprio segmentador.</div>"
