	measure 'Ticket Medio' = DIVIDE ( [Receita Total], [Lancamentos de Receita] )
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 01 Base
		lineageTag: 07716641-3148-4586-a577-9868de130e0b

	measure 'Valor Medio por Lancamento' = DIVIDE ( [Receita Total] + [Despesa Total], [Total de Lancamentos] )
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 01 Base
		lineageTag: 988fbadb-1be3-440c-89ed-4f6e487e9b9f

	measure 'Variacao Receita vs Mes Anterior' = [Receita Total] - [Receita Mes Anterior]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: a1925e67-75a5-4f36-a034-1d8b5838246b

	measure 'Variacao Receita % vs Mes Anterior' = DIVIDE ( [Variacao Receita vs Mes Anterior], [Receita Mes Anterior] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 02 Temporal
		lineageTag: 40b068ab-fbd5-4a34-a1ea-4ce4c4d06665

	measure 'Variacao Despesa vs Mes Anterior' = [Despesa Total] - [Despesa Mes Anterior]
		formatString: R$ #,##0.00;-R$ #,##0.00;R$ #,##0.00
		displayFolder: 02 Temporal
		lineageTag: 7ed00aec-a0e0-46d5-8355-f2a4130b3f61

	measure 'Variacao Despesa % vs Mes Anterior' = DIVIDE ( [Variacao Despesa vs Mes Anterior], [Despesa Mes Anterior] )
