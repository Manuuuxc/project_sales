		lineageTag: 76b2c87f-3666-4f85-9712-5ed803fb35b2

	measure 'HTML KPI Receita' =
			VAR Valor = [Receita Total]
			VAR Delta = [Variacao Receita % vs Mes Anterior]
			VAR Positivo = Delta >= 0
			VAR Cor = IF ( Positivo, "#34D399", "#F87171" )
			VAR Fundo = IF ( Positivo, "rgba(52,211,153,.14)", "rgba(248,113,113,.14)" )
			VAR Icone = IF ( Positivo, "&#8593;", "&#8595;" )
			VAR DeltaTexto = IF ( ISBLANK ( Delta ), "Sem base", FORMAT ( Delta, "+0.0%;-0.0%;0.0%" ) )
			RETURN
			    "<div style='box-sizing:border-box;height:100%;padding:16px 17px;border-radius:18px;background:linear-gradient(180deg,rgba(17,27,44,.98),rgba(11,18,32,.98));border:1px solid rgba(56,189,248,.18);box-shadow:0 12px 28px rgba(0,0,0,.26);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
			    & "<div style='display:flex;align-items:center;justify-content:space-between'><span style='font-size:11px;text-transform:uppercase;letter-spacing:.11em;color:#94A3B8;font-weight:700'>Receita</span><span style='width:28px;height:28px;border-radius:10px;background:rgba(56,189,248,.14);color:#38BDF8;text-align:center;line-height:28px;font-weight:800'>R</span></div>"
			    & "<div style='margin-top:14px;font-size:27px;line-height:30px;font-weight:750;color:#F8FAFC'>" & FORMAT ( Valor, "R$ #,##0.00" ) & "</div>"
			    & "<div style='margin-top:12px;display:inline-flex;align-items:center;gap:6px;padding:5px 9px;border-radius:999px;background:" & Fundo & ";color:" & Cor & ";font-size:12px;font-weight:700'>" & Icone & " " & DeltaTexto & "</div>"
			    & "<div style='margin-top:8px;font-size:11px;color:#64748B'>vs mes anterior</div>"
			    & "</div>"
		displayFolder: 05 HTML
		lineageTag: 3f66bb43-a172-4860-9e67-1e92868af56e

	measure 'HTML KPI Despesa' =
			VAR Valor = [Despesa Total]
			VAR Delta = [Variacao Despesa % vs Mes Anterior]
			VAR Favoravel = [Variacao Despesa vs Mes Anterior] <= 0
			VAR Cor = IF ( Favoravel, "#34D399", "#F87171" )
			VAR Fundo = IF ( Favoravel, "rgba(52,211,153,.14)", "rgba(248,113,113,.14)" )
			VAR Icone = IF ( Favoravel, "&#8595;", "&#8593;" )
			VAR DeltaTexto = IF ( ISBLANK ( Delta ), "Sem base", FORMAT ( Delta, "+0.0%;-0.0%;0.0%" ) )
			RETURN
			    "<div style='box-sizing:border-box;height:100%;padding:16px 17px;border-radius:18px;background:linear-gradient(180deg,rgba(17,27,44,.98),rgba(11,18,32,.98));border:1px solid rgba(248,113,113,.18);box-shadow:0 12px 28px rgba(0,0,0,.26);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
			    & "<div style='display:flex;align-items:center;justify-content:space-between'><span style='font-size:11px;text-transform:uppercase;letter-spacing:.11em;color:#94A3B8;font-weight:700'>Despesa</span><span style='width:28px;height:28px;border-radius:10px;background:rgba(248,113,113,.14);color:#F87171;text-align:center;line-height:28px;font-weight:800'>D</span></div>"
			    & "<div style='margin-top:14px;font-size:27px;line-height:30px;font-weight:750;color:#F8FAFC'>" & FORMAT ( Valor, "R$ #,##0.00" ) & "</div>"
			    & "<div style='margin-top:12px;display:inline-flex;align-items:center;gap:6px;padding:5px 9px;border-radius:999px;background:" & Fundo & ";color:" & Cor & ";font-size:12px;font-weight:700'>" & Icone & " " & DeltaTexto & "</div>"
			    & "<div style='margin-top:8px;font-size:11px;color:#64748B'>controle de gastos</div>"
			    & "</div>"
		displayFolder: 05 HTML
		lineageTag: 71915a8f-8ea9-4b4d-a420-281c9cf184bb

	measure 'HTML KPI Resultado' =
			VAR Valor = [Resultado]
			VAR Delta = [Variacao Resultado % vs Mes Anterior]
			VAR Positivo = Valor >= 0
			VAR Cor = IF ( Positivo, "#34D399", "#F87171" )
			VAR Fundo = IF ( Positivo, "rgba(52,211,153,.14)", "rgba(248,113,113,.14)" )
			VAR Icone = IF ( Positivo, "&#8593;", "&#8595;" )
			VAR DeltaTexto = IF ( ISBLANK ( Delta ), "Sem base", FORMAT ( Delta, "+0.0%;-0.0%;0.0%" ) )
			RETURN
			    "<div style='box-sizing:border-box;height:100%;padding:16px 17px;border-radius:18px;background:linear-gradient(180deg,rgba(17,27,44,.98),rgba(11,18,32,.98));border:1px solid rgba(52,211,153,.20);box-shadow:0 12px 28px rgba(0,0,0,.26);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
			    & "<div style='display:flex;align-items:center;justify-content:space-between'><span style='font-size:11px;text-transform:uppercase;letter-spacing:.11em;color:#94A3B8;font-weight:700'>Resultado</span><span style='width:28px;height:28px;border-radius:10px;background:" & Fundo & ";color:" & Cor & ";text-align:center;line-height:28px;font-weight:800'>" & Icone & "</span></div>"
			    & "<div style='margin-top:14px;font-size:27px;line-height:30px;font-weight:750;color:" & Cor & "'>" & FORMAT ( Valor, "R$ #,##0.00" ) & "</div>"
			    & "<div style='margin-top:12px;display:inline-flex;align-items:center;gap:6px;padding:5px 9px;border-radius:999px;background:" & Fundo & ";color:" & Cor & ";font-size:12px;font-weight:700'>" & DeltaTexto & "</div>"
			    & "<div style='margin-top:8px;font-size:11px;color:#64748B'>performance liquida</div>"
			    & "</div>"
		displayFolder: 05 HTML
		lineageTag: 265b7891-69db-4950-a036-4a3bfbe1d18a

	measure 'HTML KPI Margem' =
			VAR Valor = [Margem de Resultado %]
			VAR Delta = [Variacao Resultado % vs Mes Anterior]
			VAR Positivo = Valor >= 0
			VAR Cor = IF ( Positivo, "#38BDF8", "#F87171" )
			VAR Fundo = IF ( Positivo, "rgba(56,189,248,.14)", "rgba(248,113,113,.14)" )
			VAR DeltaTexto = IF ( ISBLANK ( Delta ), "Sem base", FORMAT ( Delta, "+0.0%;-0.0%;0.0%" ) )
			RETURN
			    "<div style='box-sizing:border-box;height:100%;padding:16px 17px;border-radius:18px;background:linear-gradient(180deg,rgba(17,27,44,.98),rgba(11,18,32,.98));border:1px solid rgba(56,189,248,.18);box-shadow:0 12px 28px rgba(0,0,0,.26);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
			    & "<div style='display:flex;align-items:center;justify-content:space-between'><span style='font-size:11px;text-transform:uppercase;letter-spacing:.11em;color:#94A3B8;font-weight:700'>Margem</span><span style='width:28px;height:28px;border-radius:10px;background:rgba(56,189,248,.14);color:#38BDF8;text-align:center;line-height:28px;font-weight:800'>%</span></div>"
			    & "<div style='margin-top:14px;font-size:31px;line-height:30px;font-weight:750;color:" & Cor & "'>" & FORMAT ( Valor, "0.0%" ) & "</div>"
			    & "<div style='margin-top:12px;display:inline-flex;align-items:center;gap:6px;padding:5px 9px;border-radius:999px;background:" & Fundo & ";color:" & Cor & ";font-size:12px;font-weight:700'>" & DeltaTexto & "</div>"
			    & "<div style='margin-top:8px;font-size:11px;color:#64748B'>rentabilidade</div>"
			    & "</div>"
		displayFolder: 05 HTML
		lineageTag: 8b0d601f-fcf8-4f7f-a902-a4422f3e8238

	measure 'HTML KPI Lancamentos' =
			"<div style='box-sizing:border-box;height:100%;padding:16px 17px;border-radius:18px;background:linear-gradient(180deg,rgba(17,27,44,.98),rgba(11,18,32,.98));border:1px solid rgba(167,139,250,.18);box-shadow:0 12px 28px rgba(0,0,0,.26);font-family:Segoe UI,Inter,Arial,sans-serif;color:#F8FAFC'>"
			& "<div style='display:flex;align-items:center;justify-content:space-between'><span style='font-size:11px;text-transform:uppercase;letter-spacing:.11em;color:#94A3B8;font-weight:700'>Lancamentos</span><span style='width:28px;height:28px;border-radius:10px;background:rgba(167,139,250,.14);color:#A78BFA;text-align:center;line-height:28px;font-weight:800'>#</span></div>"
