	partition dim_calendario = calculated
		mode: import
		source = ```
				
				VAR DataMin = DATE(2023,1,1)
				VAR DataMax = DATE(2025,12,31)
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( DataMin, DataMax ),
				    
				    "Ano", YEAR ( [Date] ),
				    "MesNumero", MONTH ( [Date] ),
				    "MesNome", FORMAT ( [Date], "MMMM" ),
				    "MesAno", FORMAT ( [Date], "MMM/YYYY" ),
				    "AnoMes", YEAR([Date]) * 100 + MONTH([Date]),
				    
				    "Trimestre", "T" & FORMAT ( [Date], "Q" ),
				    "AnoTrimestre", YEAR([Date]) & "-T" & FORMAT([Date], "Q"),
				
				    "Dia", DAY ( [Date] ),
				    "DiaSemanaNumero", WEEKDAY ( [Date], 2 ),         -- 1=Segunda, 7=Domingo
				    "DiaSemanaNome", FORMAT ( [Date], "dddd" ),
				
				    "SemanaAno", WEEKNUM ( [Date], 2 ),
				    "FimDeSemana", IF ( WEEKDAY ( [Date], 2 ) >= 6, TRUE(), FALSE() ),
				
				    "InicioDoMes", DATE ( YEAR ( [Date] ), MONTH ( [Date] ), 1 ),
				    "FimDoMes", EOMONTH ( [Date], 0 )
				)
				
				```

	annotation PBI_Id = 3aa2001c48cf43569056ce152c97110b

