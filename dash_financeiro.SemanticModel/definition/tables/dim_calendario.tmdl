	partition dim_calendario = calculated
		mode: import
		source = ```
				
				VAR DataMinFonte =
				    MINX (
				        ALL ( fat_lancamentos_financeiros ),
				        fat_lancamentos_financeiros[data_lancamento]
				    )
				VAR DataMaxFonte =
				    MAXX (
				        ALL ( fat_lancamentos_financeiros ),
				        fat_lancamentos_financeiros[data_lancamento]
				    )
				VAR DataMin =
				    DATE ( YEAR ( COALESCE ( DataMinFonte, DATE ( 2023, 1, 1 ) ) ), 1, 1 )
				VAR DataMax =
				    DATE ( YEAR ( COALESCE ( DataMaxFonte, DATE ( 2025, 12, 31 ) ) ), 12, 31 )
				VAR Base =
				    CALENDAR ( DataMin, DataMax )
				RETURN
				    SELECTCOLUMNS (
				        ADDCOLUMNS (
				            Base,
				            "Ano", YEAR ( [Date] ),
				            "Mes Numero", MONTH ( [Date] ),
				            "Mes Nome", FORMAT ( [Date], "mmmm" ),
				            "Ano Mes", FORMAT ( [Date], "MMM/yyyy" ),
				            "Trimestre", "T" & FORMAT ( [Date], "Q" ),
				            "Semestre", IF ( MONTH ( [Date] ) <= 6, "S1", "S2" ),
				            "Inicio do Mes", DATE ( YEAR ( [Date] ), MONTH ( [Date] ), 1 ),
				            "Fim do Mes", EOMONTH ( [Date], 0 ),
				            "Dia", DAY ( [Date] ),
				            "Dia da Semana", WEEKDAY ( [Date], 2 ),
				            "Nome do Dia da Semana", FORMAT ( [Date], "dddd" ),
				            "Ordem Ano Mes", YEAR ( [Date] ) * 100 + MONTH ( [Date] )
				        ),
				        "Data", [Date],
				        "Ano", [Ano],
				        "Mes Numero", [Mes Numero],
				        "Mes Nome", [Mes Nome],
				        "Ano Mes", [Ano Mes],
				        "Trimestre", [Trimestre],
				        "Semestre", [Semestre],
				        "Inicio do Mes", [Inicio do Mes],
				        "Fim do Mes", [Fim do Mes],
				        "Dia", [Dia],
				        "Dia da Semana", [Dia da Semana],
				        "Nome do Dia da Semana", [Nome do Dia da Semana],
				        "Ordem Ano Mes", [Ordem Ano Mes]
				    )
				
				```

	annotation PBI_Id = 3aa2001c48cf43569056ce152c97110b

